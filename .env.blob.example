OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1.5

DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.5-flash
DASHSCOPE_VISION_MODEL=qwen3.5-flash

RENDER_STORE=blob
BLOB_READ_WRITE_TOKEN=

# Only set this in Vercel when you want the single-project background renderer.
RENDER_EXECUTION_MODE=

# Optional hosted Remotion runtime root. Browser files live under node_modules/.remotion inside this directory.
# Hosted renders default to /tmp/renkumi/remotion-browser automatically.
REMOTION_BROWSER_CACHE_DIR=
